# Phase Bot Configuration

# Sui RPC endpoint
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Bot keypair (base64 encoded Sui keypair)
# Generate with: sui keytool generate ed25519
# Export with: sui keytool export --key-identity <alias>
BOT_KEYPAIR=

# Prediction market package ID (required)
# The published package ID of the prediction_market Move package
PM_PACKAGE_ID=0x0

# Health check port (default: 3000)
# Used by Kubernetes/Docker healthchecks to verify bot is running
HEALTH_PORT=3000

# Logging level (default: info)
# Options: debug, info, warn, error
LOG_LEVEL=info

# Poll interval (milliseconds, default: 60000)
# How often to check for voting deadlines
# Example: 60000 = 1 minute, 300000 = 5 minutes
POLL_INTERVAL_MS=60000
