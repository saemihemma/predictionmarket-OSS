# Sui RPC endpoint
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Bot private key (Bech32 suiprivkey... string)
BOT_KEYPAIR=

# Optional manifest path. When present, package ID / collateral type / staking pool
# can be sourced from the manifest instead of repeated here.
PM_MANIFEST_PATH=../deployments/testnet.json

# Explicit overrides. Leave empty if PM_MANIFEST_PATH is valid.
PM_PACKAGE_ID=
PM_COLLATERAL_COIN_TYPE=
PM_STAKING_POOL_ID=

# Health server port
HEALTH_PORT=3000

# Poll interval in milliseconds
POLL_INTERVAL_MS=60000

# Log level
LOG_LEVEL=info
