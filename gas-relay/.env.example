# Gas relay sponsor keypair (base64 encoded Sui keypair)
# Generate with: sui keytool generate ed25519
# Export with: sui keytool export --key-identity <alias>
# Testnet sponsor alias: kind-cyanite
SPONSOR_KEYPAIR_B64=

# Sui RPC endpoint
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Allowed prediction market package ID (reject txs targeting other packages)
# REQUIRED — relay will reject all transactions if this is 0x0
PM_PACKAGE_ID=0x0

# Server port
PORT=3001

# Max gas budget per transaction (in MIST, 1 SUI = 1e9 MIST)
MAX_GAS_BUDGET=50000000

# Minimum sponsor SUI balance before alerting (in MIST)
MIN_SPONSOR_BALANCE=1000000000

# CORS origin (default: * for testnet, set to your frontend URL in production)
ALLOWED_ORIGIN=*

# Global rate limit: max requests per minute to /v1/* routes (default: 120)
RATE_LIMIT=120

# API key (optional — leave empty for testnet, set for production)
# When set, all /v1/* requests must include header: x-api-key: <key>
API_KEY=
