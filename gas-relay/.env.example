# Sponsor wallet private key (Bech32 suiprivkey... string)
SPONSOR_KEYPAIR=

# Sui RPC endpoint
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Active prediction-market package ID
PM_PACKAGE_ID=0x0

# Server port
PORT=3001

# Max sponsored gas budget per transaction (MIST)
MAX_GAS_BUDGET=50000000

# Warn when sponsor wallet falls below this balance (MIST)
MIN_SPONSOR_BALANCE=1000000000

# Mark health degraded when sponsor wallet falls below this balance (MIST)
LOW_BALANCE_THRESHOLD=10000000000

# Browser/frontend origin for CORS (include scheme in deployed envs)
ALLOWED_ORIGIN=*

# Global route rate limit for /v1/* requests
RATE_LIMIT=120

# Per-dispute and per-sender live-flow rate limits
DISPUTE_RATE_LIMIT=100
SENDER_RATE_LIMIT=20

# Optional API key for non-testnet usage
API_KEY=
